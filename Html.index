<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Elite Watches \u2013 Timeless Luxury</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400;1,600&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=Cinzel:wght@400;500;600&display=swap" rel="stylesheet"/>
<style>
:root{
  --gold:#c9a84c;--gold2:#e8c97a;--gold3:#8b6914;
  --cream:#f7f2ea;--cream2:#ede7d9;
  --dark:#120f0c;--dark2:#1e180f;--dark3:#2c2318;
  --text:#3a2e24;--muted:#7a6a55;
  --border:rgba(201,168,76,.28);
  --r:0px;
}
*{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{font-family:'Cormorant Garamond',serif;background:var(--cream);color:var(--text);overflow-x:hidden;cursor:none}

/* custom cursor */
#cur{position:fixed;width:12px;height:12px;background:var(--gold);border-radius:50%;pointer-events:none;z-index:9999;transform:translate(-50%,-50%);transition:transform .15s,width .2s,height .2s}
#cur2{position:fixed;width:36px;height:36px;border:1px solid var(--gold);border-radius:50%;pointer-events:none;z-index:9998;transform:translate(-50%,-50%);transition:transform .08s,width .2s,height .2s;opacity:.6}

/* \u2500\u2500 NAVBAR \u2500\u2500 */
nav{position:fixed;top:0;width:100%;z-index:900;background:rgba(18,15,12,.96);border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;padding:0 5%;height:70px;backdrop-filter:blur(12px)}
.logo{font-family:'Cinzel',serif;font-size:1.4rem;letter-spacing:5px;color:var(--gold);text-decoration:none}
.logo span{color:#fff}
.nav-links{display:flex;gap:2rem;list-style:none}
.nav-links a{font-family:'Cinzel',serif;font-size:.65rem;letter-spacing:3px;text-transform:uppercase;color:#bbb;text-decoration:none;transition:color .3s;position:relative}
.nav-links a::after{content:'';position:absolute;bottom:-4px;left:0;width:0;height:1px;background:var(--gold);transition:width .3s}
.nav-links a:hover{color:var(--gold)}
.nav-links a:hover::after{width:100%}
.cart-btn{position:relative;background:none;border:1px solid var(--border);padding:8px 18px;color:var(--gold);font-family:'Cinzel',serif;font-size:.65rem;letter-spacing:3px;cursor:pointer;transition:all .3s;display:flex;align-items:center;gap:8px}
.cart-btn:hover{background:var(--gold);color:var(--dark)}
.cart-count{background:var(--gold);color:var(--dark);width:18px;height:18px;border-radius:50%;font-size:.6rem;display:flex;align-items:center;justify-content:center;font-weight:700}

/* \u2500\u2500 CART DRAWER \u2500\u2500 */
.cart-overlay{position:fixed;inset:0;background:rgba(0,0,0,.6);z-index:1000;opacity:0;pointer-events:none;transition:opacity .35s}
.cart-overlay.open{opacity:1;pointer-events:all}
.cart-drawer{position:fixed;top:0;right:-460px;width:420px;max-width:95vw;height:100vh;background:var(--dark);border-left:1px solid var(--border);z-index:1001;transition:right .4s cubic-bezier(.22,1,.36,1);display:flex;flex-direction:column;overflow:hidden}
.cart-drawer.open{right:0}
.cart-header{padding:24px 28px;border-bottom:1px solid var(--border);display:flex;justify-content:space-between;align-items:center}
.cart-header h3{font-family:'Cinzel',serif;font-size:.85rem;letter-spacing:4px;color:var(--gold);text-transform:uppercase}
.cart-close{background:none;border:none;color:#fff;font-size:1.4rem;cursor:pointer;opacity:.6;transition:opacity .2s}
.cart-close:hover{opacity:1}
.cart-items{flex:1;overflow-y:auto;padding:20px 28px}
.cart-empty{text-align:center;color:rgba(255,255,255,.3);padding:60px 0;font-family:'Cinzel',serif;font-size:.7rem;letter-spacing:3px}
.cart-item{display:flex;gap:14px;padding:16px 0;border-bottom:1px solid rgba(255,255,255,.06);align-items:center}
.cart-item-img{width:60px;height:60px;flex-shrink:0;background:var(--dark2);border:1px solid var(--border);display:flex;align-items:center;justify-content:center}
.cart-item-info{flex:1}
.cart-item-name{font-family:'Playfair Display',serif;font-size:.95rem;color:#fff;margin-bottom:4px}
.cart-item-price{font-family:'Cinzel',serif;font-size:.75rem;color:var(--gold)}
.cart-item-remove{background:none;border:none;color:rgba(255,255,255,.3);cursor:pointer;font-size:1.1rem;transition:color .2s}
.cart-item-remove:hover{color:#e44}
.cart-footer{padding:24px 28px;border-top:1px solid var(--border)}
.cart-total{display:flex;justify-content:space-between;margin-bottom:20px}
.cart-total span:first-child{font-family:'Cinzel',serif;font-size:.7rem;letter-spacing:3px;color:rgba(255,255,255,.4);text-transform:uppercase}
.cart-total span:last-child{font-family:'Playfair Display',serif;font-size:1.3rem;color:var(--gold)}
.checkout-btn{width:100%;padding:14px;background:var(--gold);color:var(--dark);border:none;font-family:'Cinzel',serif;font-size:.7rem;letter-spacing:4px;text-transform:uppercase;cursor:pointer;transition:background .3s}
.checkout-btn:hover{background:var(--gold2)}

/* \u2500\u2500 HERO \u2500\u2500 */
#hero{height:100vh;background:radial-gradient(ellipse at 60% 50%,#1e1608 0%,#0d0b08 100%);display:flex;align-items:center;position:relative;overflow:hidden;padding:0 8%}
.hero-noise{position:absolute;inset:0;opacity:.04;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");background-size:200px}
.hero-lines{position:absolute;inset:0}
.hero-lines::before,.hero-lines::after{content:'';position:absolute;border-radius:50%;border:1px solid rgba(201,168,76,.08)}
.hero-lines::before{width:70vmin;height:70vmin;top:50%;right:5%;transform:translateY(-50%)}
.hero-lines::after{width:55vmin;height:55vmin;top:50%;right:10%;transform:translateY(-50%)}
.hero-text{max-width:600px;position:relative;z-index:2}
.hero-tag{font-family:'Cinzel',serif;font-size:.6rem;letter-spacing:8px;color:var(--gold);text-transform:uppercase;margin-bottom:1.5rem;opacity:0;animation:fadeUp .8s .2s forwards}
.hero-h1{font-family:'Playfair Display',serif;font-size:clamp(3rem,7vw,6.5rem);font-weight:400;color:#fff;line-height:1.05;margin-bottom:1.2rem;opacity:0;animation:fadeUp .9s .4s forwards}
.hero-h1 em{font-style:italic;color:var(--gold)}
.hero-p{font-size:1.1rem;color:rgba(255,255,255,.45);line-height:1.8;margin-bottom:2.5rem;font-weight:300;opacity:0;animation:fadeUp .9s .6s forwards}
.hero-btns{display:flex;gap:1.2rem;flex-wrap:wrap;opacity:0;animation:fadeUp .9s .8s forwards}
.btn-g{display:inline-block;padding:13px 38px;border:1px solid var(--gold);color:var(--gold);font-family:'Cinzel',serif;font-size:.65rem;letter-spacing:4px;text-transform:uppercase;text-decoration:none;background:none;cursor:pointer;transition:all .3s;position:relative;overflow:hidden}
.btn-g::before{content:'';position:absolute;inset:0;background:var(--gold);transform:translateX(-101%);transition:transform .3s ease;z-index:-1}
.btn-g:hover{color:var(--dark)}
.btn-g:hover::before{transform:translateX(0)}
.btn-g.solid{background:var(--gold);color:var(--dark)}
.btn-g.solid:hover{background:var(--gold2)}
.hero-watch-display{position:absolute;right:8%;top:50%;transform:translateY(-50%);z-index:2;opacity:0;animation:fadeLeft .9s .5s forwards}
@keyframes fadeUp{from{opacity:0;transform:translateY(24px)}to{opacity:1;transform:none}}
@keyframes fadeLeft{from{opacity:0;transform:translateY(-50%) translateX(40px)}to{opacity:1;transform:translateY(-50%) translateX(0)}}

/* \u2500\u2500 SECTION COMMONS \u2500\u2500 */
.sec{padding:100px 8%}
.s-tag{font-family:'Cinzel',serif;font-size:.6rem;letter-spacing:6px;color:var(--gold);text-transform:uppercase;display:block;margin-bottom:.8rem}
.s-title{font-family:'Playfair Display',serif;font-size:clamp(1.8rem,3.5vw,3rem);font-weight:400;color:var(--dark);line-height:1.2;margin-bottom:1.5rem}
.s-title em{font-style:italic}
.s-title.light{color:#fff}
.ruler{display:flex;align-items:center;gap:10px;margin-bottom:2.5rem}
.ruler span{flex:1;height:1px;background:var(--border)}
.ruler i{width:7px;height:7px;border:1px solid var(--gold);transform:rotate(45deg);display:block;flex-shrink:0}

/* \u2500\u2500 COLLECTION \u2500\u2500 */
#collection{background:#fff}
.col-head{text-align:center;margin-bottom:3.5rem}
.watches-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:1.8rem}

/* watch card */
.wcard{background:var(--cream);border:1px solid rgba(201,168,76,.18);overflow:hidden;transition:transform .4s,box-shadow .4s;position:relative}
.wcard:hover{transform:translateY(-10px);box-shadow:0 24px 60px rgba(0,0,0,.13)}
.wcard-img{height:290px;background:linear-gradient(145deg,#181008,#251d10);display:flex;align-items:center;justify-content:center;position:relative;overflow:hidden}
.wcard-img::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 50% 30%,rgba(201,168,76,.08),transparent 70%)}
.badge{position:absolute;top:14px;left:14px;background:var(--gold);color:var(--dark);font-family:'Cinzel',serif;font-size:.52rem;letter-spacing:2px;padding:4px 10px;text-transform:uppercase}
.wcard-body{padding:1.4rem}
.wcard-name{font-family:'Playfair Display',serif;font-size:1.2rem;color:var(--dark);margin-bottom:.35rem}
.wcard-desc{font-size:.92rem;color:var(--muted);line-height:1.65;margin-bottom:1rem}
.wcard-foot{display:flex;align-items:center;justify-content:space-between}
.wcard-price{font-family:'Cinzel',serif;font-size:1rem;color:var(--gold3)}
.add-cart{background:var(--dark);color:var(--gold);border:none;padding:9px 20px;font-family:'Cinzel',serif;font-size:.58rem;letter-spacing:2.5px;text-transform:uppercase;cursor:pointer;transition:all .3s;display:flex;align-items:center;gap:7px}
.add-cart:hover{background:var(--gold);color:var(--dark)}
.add-cart svg{width:13px;height:13px;fill:currentColor}

/* \u2500\u2500 SVG WATCHES \u2500\u2500 */
.watch-svg{width:150px;height:180px;filter:drop-shadow(0 8px 24px rgba(0,0,0,.5))}

/* \u2500\u2500 ABOUT \u2500\u2500 */
#about{background:var(--dark);display:grid;grid-template-columns:1fr 1fr;gap:6rem;align-items:center}
.about-art{position:relative;display:flex;align-items:center;justify-content:center;height:400px}
.a-ring{position:absolute;border-radius:50%;border:1px solid var(--border)}
.a-ring:nth-child(1){width:360px;height:360px;animation:spin 90s linear infinite}
.a-ring:nth-child(2){width:280px;height:280px;border-color:rgba(201,168,76,.15);animation:spin 70s linear infinite reverse}
.a-center{width:180px;height:180px;border-radius:50%;background:radial-gradient(circle,#2a1e0e,#0d0b07);border:2px solid var(--gold);display:flex;align-items:center;justify-content:center;text-align:center;flex-direction:column;gap:4px;z-index:2}
.a-center p{font-family:'Cinzel',serif;font-size:.55rem;letter-spacing:4px;color:var(--gold)}
.a-center h2{font-family:'Playfair Display',serif;font-size:2.4rem;color:#fff;font-weight:400}
@keyframes spin{to{transform:rotate(360deg)}}
.about-p{font-size:1rem;color:rgba(255,255,255,.55);line-height:1.9;margin-bottom:1.2rem}
.stats{display:flex;gap:2.5rem;margin-top:2rem}
.stat .n{font-family:'Playfair Display',serif;font-size:2.2rem;color:var(--gold)}
.stat .l{font-family:'Cinzel',serif;font-size:.58rem;letter-spacing:3px;color:rgba(255,255,255,.35);text-transform:uppercase}

/* \u2500\u2500 BLOG \u2500\u2500 */
#blog{background:var(--cream2)}
.blog-head{text-align:center;margin-bottom:3.5rem}
.blog-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:2rem}
.bcard{background:#fff;border:1px solid rgba(201,168,76,.15);overflow:hidden;transition:transform .35s,box-shadow .35s;cursor:pointer}
.bcard:hover{transform:translateY(-6px);box-shadow:0 18px 50px rgba(0,0,0,.09)}
.bcard-img{height:200px;position:relative;overflow:hidden;display:flex;align-items:center;justify-content:center}
.bcard-cat{position:absolute;bottom:14px;left:14px;background:var(--gold);color:var(--dark);font-family:'Cinzel',serif;font-size:.52rem;letter-spacing:2px;padding:4px 10px;text-transform:uppercase}
.bcard-body{padding:1.4rem}
.bcard-date{font-family:'Cinzel',serif;font-size:.58rem;letter-spacing:3px;color:var(--muted);text-transform:uppercase;margin-bottom:.7rem}
.bcard-title{font-family:'Playfair Display',serif;font-size:1.25rem;color:var(--dark);line-height:1.3;margin-bottom:.7rem}
.bcard-text{font-size:.92rem;color:var(--muted);line-height:1.65;margin-bottom:1rem}
.bcard-read{font-family:'Cinzel',serif;font-size:.6rem;letter-spacing:3px;color:var(--gold3);text-transform:uppercase;text-decoration:none;display:inline-flex;align-items:center;gap:7px;transition:gap .3s}
.bcard:hover .bcard-read{gap:14px}

/* \u2500\u2500 CONTACT \u2500\u2500 */
#contact{background:var(--dark2)}
.contact-wrap{max-width:780px;margin:0 auto;text-align:center}
.contact-sub{font-size:1rem;color:rgba(255,255,255,.4);margin-bottom:3rem;letter-spacing:1px}
.fgrid{display:grid;grid-template-columns:1fr 1fr;gap:1.2rem;margin-bottom:1.2rem;text-align:left}
.fg{display:flex;flex-direction:column}
.fg.full{grid-column:1/-1}
.fg label{font-family:'Cinzel',serif;font-size:.58rem;letter-spacing:3px;color:var(--gold);text-transform:uppercase;margin-bottom:.5rem}
.fg input,.fg textarea,.fg select{background:rgba(255,255,255,.05);border:1px solid rgba(201,168,76,.2);padding:12px 15px;font-family:'Cormorant Garamond',serif;font-size:1rem;color:#fff;outline:none;transition:border-color .3s;resize:none;-webkit-appearance:none}
.fg input::placeholder,.fg textarea::placeholder{color:rgba(255,255,255,.25)}
.fg input:focus,.fg textarea:focus,.fg select:focus{border-color:var(--gold)}
.fg select option{background:var(--dark)}
.fg textarea{height:120px}
.fsub{margin-top:1.5rem}
.contact-info{display:flex;justify-content:center;gap:3rem;margin-top:3rem;flex-wrap:wrap}
.ci{text-align:center}
.ci-l{font-family:'Cinzel',serif;font-size:.58rem;letter-spacing:3px;color:var(--gold);text-transform:uppercase;margin-bottom:.4rem}
.ci-v{color:rgba(255,255,255,.6);font-size:.95rem}
.ok-msg{display:none;margin-top:1.5rem;color:var(--gold);font-family:'Cinzel',serif;font-size:.72rem;letter-spacing:3px}

/* \u2500\u2500 FOOTER \u2500\u2500 */
footer{background:var(--dark);padding:3rem 8%;text-align:center;border-top:1px solid var(--border)}
.f-logo{font-family:'Cinzel',serif;font-size:1.2rem;letter-spacing:6px;color:var(--gold);margin-bottom:.8rem}
.f-copy{font-size:.78rem;color:rgba(255,255,255,.2);letter-spacing:2px}

/* \u2500\u2500 TOAST \u2500\u2500 */
.toast{position:fixed;bottom:30px;left:50%;transform:translateX(-50%) translateY(80px);background:var(--dark);border:1px solid var(--gold);color:var(--gold);font-family:'Cinzel',serif;font-size:.65rem;letter-spacing:3px;padding:12px 28px;z-index:9999;transition:transform .4s ease;white-space:nowrap}
.toast.show{transform:translateX(-50%) translateY(0)}

@media(max-width:768px){
  #about{grid-template-columns:1fr;gap:3